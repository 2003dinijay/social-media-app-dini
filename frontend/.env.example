# Copy this file to .env and fill in the values from your WSO2 Identity Server
# Service Provider registration (Step 2 of the learning guide).

# The OIDC "authority" — WSO2 IS issuer URL. If your IS runs on the default
# port 9443, use https://localhost:9443/oauth2/token instead.
VITE_OIDC_AUTHORITY=https://localhost:9445/oauth2/token

# Client ID you got after registering the SPA in the IS Management Console.
VITE_OIDC_CLIENT_ID=YOUR_CLIENT_ID_HERE

# Must exactly match the Callback URL you set on the Service Provider.
VITE_OIDC_REDIRECT_URI=http://localhost:3000

# Base URL of your Ballerina backend (note: https, self-signed cert — see README).
VITE_API_BASE_URL=https://localhost:9090/social_media
